# ── LLM Provider ──────────────────────────────────────────────────────────────
# Options: openai | anthropic | bedrock | ollama | huggingface | azure_openai | groq
LLM_PROVIDER=bedrock

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ── AWS Bedrock ───────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# ── Groq ──────────────────────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=mixtral-8x7b-32768

# ── Ollama (local) ────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ── HuggingFace ───────────────────────────────────────────────────────────────
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ── LLM Behaviour ─────────────────────────────────────────────────────────────
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=60

# ── Agent Behaviour ───────────────────────────────────────────────────────────
MAX_ITERATIONS=10
MAX_RETRIES=3
RETRY_DELAY=1.0

# ── Persistence ───────────────────────────────────────────────────────────────
# Options: memory | sqlite | postgres
CHECKPOINTER=memory
SQLITE_DB_PATH=./checkpoints.db
POSTGRES_CONNECTION_STRING=

# ── Observability ─────────────────────────────────────────────────────────────
# Options: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=langgraph-production
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ── Tools ─────────────────────────────────────────────────────────────────────
TAVILY_API_KEY=

# ── RAG ───────────────────────────────────────────────────────────────────────
RAG_ENABLED=true
VECTOR_DB_PATH=./vector_db
VECTOR_COLLECTION=documents
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=4

# ── Embeddings ────────────────────────────────────────────────────────────────
# Options: local | openai
EMBEDDING_PROVIDER=local
EMBEDDING_LOCAL_MODEL=all-MiniLM-L6-v2
EMBEDDING_OPENAI_MODEL=text-embedding-3-small

# ── Offline mode (skip HuggingFace network checks) ────────────────────────────
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
SENTENCE_TRANSFORMERS_HOME=./models_cache

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# ── Human-in-the-loop ─────────────────────────────────────────────────────────
HUMAN_IN_LOOP_ENABLED=false
HUMAN_IN_LOOP_NODES=tool_executor,supervisor_run_agent